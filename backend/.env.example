# ── App ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-change-this
DEBUG=false

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=enterprise_pm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Groq AI (fallback LLM) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── AWS Bedrock (primary LLM) ─────────────────────────────────────────────────
AWS_ACCESS_KEY=AKIA_your_aws_access_key_here
AWS_BEDROCK_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@company.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@company.com

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# ── Git integration (optional — raises API rate limit 60 → 5000 req/hr) ──────
GITHUB_TOKEN=your-github-personal-access-token
GITLAB_TOKEN=your-gitlab-personal-access-token
