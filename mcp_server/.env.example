# Enterprise PM System - MCP Server Configuration
# Copy this file to .env and fill in your values

# Your deployed API base URL (no trailing slash)
PM_API_URL=https://your-tunnel.trycloudflare.com/api/v1

# Optional: pre-set JWT token (get it from the app's login response or use the login() tool)
# If not set, call the login() tool first before using other tools.
PM_API_TOKEN=
